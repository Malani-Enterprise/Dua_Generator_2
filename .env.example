# ══════════════════════════════════════════════════
# Du'a Generator — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════

# ── AI API (choose one) ──
# OpenAI
OPENAI_API_KEY=sk-...your-key-here...

# OR Anthropic
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Which provider to use: "openai" or "anthropic"
AI_PROVIDER=anthropic

# Anthropic model — change to test different models:
#   claude-opus-4-6       (best quality, $5/$25 per MTok)
#   claude-sonnet-4-6     (balanced, $3/$15 per MTok)
#   claude-haiku-4-5-20251001  (fastest/cheapest, $1/$5 per MTok)
ANTHROPIC_MODEL=claude-opus-4-6

# ── Email (for du'a delivery) ──
# Gmail example: use an App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_NAME=Du'a Generator
SMTP_FROM_EMAIL=your-email@gmail.com

# ── App Settings ──
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ── Stripe (for "Support Us" donations) ──
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...your-key-here...
STRIPE_PUBLISHABLE_KEY=pk_test_...your-key-here...

# ── Optional ──
# Set to "production" to disable debug mode
APP_ENV=development
